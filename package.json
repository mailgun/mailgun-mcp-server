{
    "name": "@mailgun/mcp-server",
    "version": "1.0.2",
    "description": "A Model Context Protocol (MCP) server for Mailgun, enabling MCP-compatible AI clients to interact with the Mailgun email service.",
    "type": "module",
    "main": "dist/mailgun-mcp.js",
    "types": "dist/mailgun-mcp.d.ts",
    "bin": {
        "mcp-server": "dist/mailgun-mcp.js",
        "mailgun-mcp-server": "dist/mailgun-mcp.js"
    },
    "license": "Apache-2.0",
    "author": "Mailgun Technologies, Inc",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mailgun/mailgun-mcp-server.git"
    },
    "bugs": {
        "url": "https://github.com/mailgun/mailgun-mcp-server/issues"
    },
    "homepage": "https://github.com/mailgun/mailgun-mcp-server#readme",
    "keywords": [
        "mailgun",
        "mcp",
        "model-context-protocol",
        "email",
        "ai"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsc && cp src/openapi.yaml dist/openapi.yaml",
        "start": "node dist/mailgun-mcp.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.7.0",
        "js-yaml": "^4.1.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.5.2",
        "eslint": "^10.0.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.3"
    }
}
