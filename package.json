{
  "name": "@mailgun/mcp-server",
  "mcpName": "com.mailgun/mailgun-mcp-server",
  "version": "2.0.0",
  "description": "An MCP server that gives AI agents a practical interface to Mailgun workflows for sending, diagnosing deliverability, and taking account actions safely.",
  "keywords": [
    "ai",
    "email",
    "mailgun",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/mailgun/mailgun-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/mailgun/mailgun-mcp-server/issues"
  },
  "license": "Apache-2.0",
  "author": "Mailgun Technologies, Inc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mailgun/mailgun-mcp-server.git"
  },
  "bin": {
    "mailgun-mcp-server": "dist/mailgun-mcp.js",
    "mcp-server": "dist/mailgun-mcp.js"
  },
  "type": "module",
  "main": "dist/mailgun-mcp.js",
  "types": "dist/mailgun-mcp.d.ts",
  "scripts": {
    "build": "tsc && cp src/openapi.yaml dist/openapi.yaml",
    "check:versions": "node scripts/check-version-sync.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "npm run check:versions && oxlint",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "npm run build",
    "start": "node dist/mailgun-mcp.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
